# 复制为 .env 并填入本地值；勿提交 .env
# 从仓库根目录执行 go run ./cmd/server 时，若存在 .env 则 godotenv.Overload：同名键以 .env 为准（覆盖系统里残留的空/旧值）。
# HTTP 监听地址（默认 :18080，见 internal/config/config.go）
# HTTP_ADDR=:18080
#
# Docker Compose：宿主机上映射 ASE 的端口（默认 18080）。与本地 go run 冲突时改为例如 18081（docker-compose.yml 使用 ${ASE_HOST_PORT:-18080}）
# ASE_HOST_PORT=18080
#
# Admin 管理页（GET /admin/）：三者齐全才启用——ADMIN_USERNAME、密码（二选一）、ADMIN_SESSION_SECRET（≥16 字符）
# ADMIN_USERNAME=
# ADMIN_PASSWORD_BCRYPT=   # 推荐；bcrypt 哈希。未设置时可用下方明文（仅开发）
# ADMIN_PASSWORD=
# ADMIN_SESSION_SECRET=
# ADMIN_SESSION_TTL_SECONDS=86400
# 第三方搜索 Provider（示例键名，实现落地后对齐代码）
# BAIDU_API_KEY=
# BING_SEARCH_KEY=

# 百度搜索（无头 Chrome + chromedp；BAIDU_BROWSER_ENABLED=true 时优先于 Tavily，见 internal/adapter/baidubrowser）
# 需安装 Chrome/Chromium；可选指定 CHROME_EXEC_PATH（如 Windows 下 chrome.exe 路径）
# BAIDU_BROWSER_ENABLED=false
# BAIDU_BROWSER_MAX_RESULTS=10
# CHROME_EXEC_PATH=
# BAIDU_BROWSER_USER_AGENT=

# Bing 搜索（无头 Chrome + chromedp；与百度并列注册，通过 providers 或 SEARCH_DEFAULT_PROVIDERS 选用）
# BING_BROWSER_ENABLED=false
# BING_BROWSER_MAX_RESULTS=10
# BING_BROWSER_USER_AGENT=
# BING_BROWSER_MARKET=zh-CN

# Google 搜索（无头 Chrome + chromedp；易遇同意条款/验证码，属尽力而为）
# GOOGLE_BROWSER_ENABLED=false
# GOOGLE_BROWSER_MAX_RESULTS=10
# GOOGLE_BROWSER_USER_AGENT=
# GOOGLE_BROWSER_HL=zh-CN
# GOOGLE_BROWSER_GL=cn

# 未在 JSON 里指定 providers 时使用的默认引擎列表（逗号分隔）。docker compose 默认为 baidu。
# SEARCH_DEFAULT_PROVIDERS=baidu

# Tavily Search（回落路径；设置后 main 使用真实 API，见 internal/adapter/tavily）
# https://docs.tavily.com/documentation/api-reference/introduction
# TAVILY_API_KEY=tvly-...
# TAVILY_BASE_URL=https://api.tavily.com
# TAVILY_MAX_RESULTS=10
# TAVILY_SEARCH_DEPTH=basic
# TAVILY_PROJECT_ID=

# 回落后对每条结果的 http(s) URL 再 GET，Readability+Markdown 填入响应里的「## 正文」
# docker compose 默认为 true；单次请求可用 POST body 的 deepsearch 覆盖。
# 百度搜索结果多为 http://www.baidu.com/link?...，此前仅支持 https 会导致无法抓取；现已支持 http/https。
# PROVIDER_FETCH_RESULT_URLS=true
# PROVIDER_FETCH_MAX_URLS=5
# FETCH_PER_URL_TIMEOUT_MS=8000
# FETCH_CONCURRENCY=4

# OpenSearch（自建索引，与 docs/DETAILED_DESIGN.md §6.3 一致）
# OPENSEARCH_URLS=https://localhost:9200
# OPENSEARCH_INDEX=ase_documents
# OPENSEARCH_USER=
# OPENSEARCH_PASSWORD=
# OPENSEARCH_SEARCH_SIZE=10

# 回落路径（provider）检索成功后将 Markdown 转写为 title/body_text 异步写入索引；同一 trim(query) 固定文档 id（默认前缀 ase-q- + SHA256）
# 默认开启；无 OpenSearch 时 noop 不写。见 internal/orchestrator/writeback.go
# SEARCH_INDEX_WRITE_BACK_ENABLED=true
# SEARCH_INDEX_WRITE_BACK_TIMEOUT_MS=5000
# SEARCH_INDEX_WRITE_BACK_MAX_CONCURRENCY=16
# SEARCH_INDEX_WRITE_BACK_MIN_BODY_RUNES=20
# SEARCH_INDEX_WRITE_BACK_MAX_BODY_RUNES=32000
# SEARCH_INDEX_WRITE_BACK_TITLE_MAX_RUNES=256
# SEARCH_INDEX_WRITE_BACK_ID_PREFIX=ase-q-

# 多个 Key 用英文逗号分隔（优先于 DEV_API_KEY）
# AUTH_VALID_API_KEYS=

# 服务对外鉴权（开发用单 Key；与 AUTH_VALID_API_KEYS 二选一逻辑见代码）
# DEV_API_KEY=

# 检索与输出（可选，缺省见 internal/config/config.go）
# MIN_HIT_COUNT=
# MIN_TOTAL_TEXT_LEN=
# MIN_SIMILARITY=
# MAX_RESPONSE_RUNES=
# MAX_QUERY_RUNES=
# REQUEST_DEADLINE_MS=

# 限流（REQ-F-011）
# RATE_LIMIT_GLOBAL_RPS=
# RATE_LIMIT_GLOBAL_BURST=
# RATE_LIMIT_PER_KEY_RPS=
# RATE_LIMIT_BURST=
